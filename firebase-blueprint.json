{
  "entities": {
    "User": {
      "title": "User",
      "description": "A doctor or clinic user",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "clinicName": { "type": "string" },
        "doctorStampBase64": { "type": "string" },
        "testCharges": { "type": "object" }
      },
      "required": ["uid", "email"]
    },
    "Patient": {
      "title": "Patient",
      "description": "A patient belonging to a doctor",
      "type": "object",
      "properties": {
        "doctorId": { "type": "string" },
        "name": { "type": "string" },
        "age": { "type": "number" },
        "gender": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "assignedTests": {
          "type": "array",
          "items": { "type": "string" }
        },
        "totalBill": { "type": "number" },
        "referredByDr": { "type": "string" },
        "clientAddress": { "type": "string" }
      },
      "required": ["doctorId", "name", "age", "gender"]
    },
    "Report": {
      "title": "Report",
      "description": "A lab report for a patient",
      "type": "object",
      "properties": {
        "doctorId": { "type": "string" },
        "patientId": { "type": "string" },
        "patientName": { "type": "string" },
        "templateId": { "type": "string" },
        "templateName": { "type": "string" },
        "results": { "type": "object" },
        "date": { "type": "string", "format": "date-time" },
        "doctorStampBase64": { "type": "string" },
        "clinicName": { "type": "string" },
        "visitLabNo": { "type": "string" },
        "referLabHosp": { "type": "string" },
        "refClient": { "type": "string" },
        "barcodeNo": { "type": "string" },
        "sampleCollectionDate": { "type": "string", "format": "date-time" },
        "sampleReceivedDate": { "type": "string", "format": "date-time" },
        "registrationDate": { "type": "string", "format": "date-time" }
      },
      "required": ["doctorId", "patientId", "patientName", "templateId", "templateName", "results", "date"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user (doctor) profiles"
    },
    "/patients/{patientId}": {
      "schema": { "$ref": "#/entities/Patient" },
      "description": "Stores patients"
    },
    "/reports/{reportId}": {
      "schema": { "$ref": "#/entities/Report" },
      "description": "Stores lab reports"
    }
  }
}